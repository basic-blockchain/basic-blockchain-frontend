    {
      "name": "Admin — users",
      "item": [
        { "name": "GET /admin/users", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/users", "host": ["{{baseUrl}}"], "path": ["admin", "users"] } } },
