{
  "info": {
    "name": "Basic Blockchain — Frontend API surface",
    "description": "Every endpoint consumed by basic-blockchain-frontend (v0.9.0 / Phase 7 closed). Mirrors docs/api-reference.md. Pair with the `local` or `staging` environment. After running `Auth > Login`, the `access_token` is captured into the `jwt` env var via a test script and re-used by every authenticated request through `{{authHeader}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "bb-frontend-2026-05-25"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt}}", "type": "string" }]
  },
  "variable": [
    { "key": "user_id", "value": "" },
    { "key": "wallet_id", "value": "" },
    { "key": "op_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"alice\",\n  \"display_name\": \"Alice\",\n  \"country\": \"AR\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "POST /auth/activate",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"alice\",\n  \"activation_code\": \"REPLACE\",\n  \"password\": \"S3cret!pass\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/activate", "host": ["{{baseUrl}}"], "path": ["auth", "activate"] }
          }
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.access_token) {",
                  "    pm.environment.set('jwt', json.access_token);",
                  "    console.log('JWT captured into env.jwt');",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
